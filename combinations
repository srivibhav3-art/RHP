#include <stdio.h>
#include <string.h>

int main()
{
    char str[100];

    scanf("%s", str);

    int len = strlen(str);

    for (int mask = 1; mask < (1 << len); mask++)
    {
        char subseq[100];
        int pos = 0;

        for (int j = 0; j < len; j++)
        {
            if (mask & (1 << j))
            {
                subseq[pos++] = str[j];
            }
        }

        subseq[pos] = '\0';

        printf("%s\n", subseq);
    }

    return 0;
}